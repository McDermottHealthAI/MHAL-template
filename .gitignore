# This is a copier template, not a Python project itself. Keep this .gitignore
# minimal — the rendered project's own .gitignore lives at template/.gitignore.

# Ephemeral / local
.claude/settings.local.json
.claude/memory/
.claude/*.lock
.claude/scheduled_tasks/

# Stuff that might appear if someone runs commands in the template repo root
__pycache__/
*.py[codz]
.venv
node_modules/
*.egg-info/
.pytest_cache/
.ruff_cache/
